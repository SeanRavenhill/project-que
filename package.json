{
  "name": "project_que",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "market trading information dashboard",
  "author": "Sean Ravenhill",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "concurrently -n \"CLIENT,SERVER\" -c \"cyan,magenta\" \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0"
  }
}
